#!/usr/bin/env ruby
# Asserts that every image id in config.yml appears in exactly one
# .github/workflows/matrix-*.yml image selection, and that workflows do not
# reference unknown image ids.

require 'yaml'
require 'json'

repo_root = File.expand_path("../..", __dir__)
config_ids = YAML.load_file(File.join(repo_root, "config.yml")).fetch("images").map { |i| i.fetch("id") }

workflow_ids = {} # image_id => [workflow files]
warnings = []
errors = []

Dir[File.join(repo_root, ".github/workflows/matrix-*.yml")].sort.each do |path|
  content = File.read(path)
  description_ids = content
    .scan(/^\s*description:\s*['"]?([^'"\n]+)['"]?\s*$/)
    .flatten
    .select { |id| config_ids.include?(id) }
  json_ids = content
    .scan(/\[\s*"[^\]]+"\s*\]/)
    .map { |s| JSON.parse(s) rescue nil }
    .compact
    .flatten
    .select { |id| config_ids.include?(id) }
  ids = description_ids.empty? ? json_ids : description_ids
  next if ids.empty?

  ids.uniq.each do |id|
    (workflow_ids[id] ||= []) << File.basename(path)
  end

  if description_ids.any? && json_ids.any? && description_ids.sort != json_ids.uniq.sort
    warnings << "#{File.basename(path)}: checkbox descriptions and JSON image lists differ"
  end
end

config_ids.each do |id|
  files = workflow_ids[id] || []
  if files.empty?
    errors << "#{id} (config.yml) is not buildable by any matrix-*.yml workflow"
  elsif files.uniq.size > 1
    errors << "#{id} appears in multiple workflows: #{files.uniq.join(', ')}"
  end
end

(workflow_ids.keys - config_ids).each do |id|
  errors << "#{id} is referenced in #{workflow_ids[id].uniq.join(', ')} but missing from config.yml"
end

warnings.each { |w| puts "WARNING: #{w}" }
if errors.any?
  errors.each { |e| puts "ERROR: #{e}" }
  exit 1
end
puts "OK: #{config_ids.size} image ids consistent across config.yml and matrix workflows"
