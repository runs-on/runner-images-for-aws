#!/usr/bin/env ruby

require 'json'
require 'open-uri'
require 'slop'
require 'fileutils'
require 'yaml'
require 'aws-sdk-ec2'
require 'timeout'
require 'tmpdir'

IMAGES = YAML.load_file(File.expand_path("../config.yml", __dir__)).fetch("images")
SUBNET_TAG_KEY = "runner-image-for-aws"
SUBNET_TAG_VALUE = "true"

options = {}

usage = Slop::Options.new do |opts|
  opts.banner = "Usage: #{$0} --image-id [IMAGE_ID] [--sync]"

  opts.string '--image-id', 'Image ID', required: true
  opts.string '--image-prefix', 'Image Prefix', default: ENV.fetch('AMI_PREFIX', "runs-on-dev")
  opts.string '--image-version', 'Image Version', default: Time.now.strftime("%Y%m%d%H%M%S")
  opts.string '--subnet-id', 'Legacy subnet ID fallback used only if no tagged subnet exists', default: nil
  opts.string '--log-file', 'Path to write Packer output (defaults to a temporary file)', default: nil
  opts.string '--region', 'Region', default: ENV.fetch('AWS_DEFAULT_REGION', "us-east-1")
  opts.boolean '--debug', 'Debug mode', default: false
  opts.boolean '--sync', 'Run bin/sync for the selected image before patching/building', default: false
end

begin
  options = usage.parse(ARGV).to_hash
rescue Slop::Error => e
  puts "Error: #{e.message}"
  puts
  puts usage
  exit 1
end

def tagged_subnets(ec2_client:, tag_key:, tag_value:)
  ec2_client.describe_subnets(
    filters: [
      { name: "state", values: ["available"] },
      { name: "tag:#{tag_key}", values: [tag_value] }
    ]
  ).subnets
end

def ensure_subnet_tag(ec2_client:, subnet_id:, tag_key:, tag_value:)
  subnet = ec2_client.describe_subnets(subnet_ids: [subnet_id]).subnets.first
  existing_value = subnet.tags&.find { |tag| tag.key == tag_key }&.value

  if existing_value == tag_value
    puts "Subnet #{subnet_id} already tagged #{tag_key}=#{tag_value}"
  else
    ec2_client.create_tags(
      resources: [subnet_id],
      tags: [{ key: tag_key, value: tag_value }]
    )
    puts "Tagged subnet #{subnet_id} with #{tag_key}=#{tag_value}"
  end

  subnet.subnet_id
rescue Aws::EC2::Errors::InvalidSubnetIDNotFound
  fail("Fallback subnet not found: #{subnet_id}")
end

def resolve_subnet_id(ec2_client:, tag_key:, tag_value:, fallback_subnet_id: nil)
  subnets = tagged_subnets(ec2_client: ec2_client, tag_key: tag_key, tag_value: tag_value)

  if subnets.length == 1
    subnet_id = subnets.first.subnet_id
    puts "Using tagged subnet #{subnet_id} (#{tag_key}=#{tag_value})"
    return subnet_id
  end

  if subnets.length > 1
    if fallback_subnet_id
      matching = subnets.find { |subnet| subnet.subnet_id == fallback_subnet_id }
      if matching
        puts "Multiple tagged subnets found; using fallback subnet #{fallback_subnet_id}"
        return matching.subnet_id
      end
    end

    subnet_ids = subnets.map(&:subnet_id).sort.join(", ")
    fail("Multiple tagged subnets found for #{tag_key}=#{tag_value}: #{subnet_ids}. Pass --subnet-id to disambiguate.")
  end

  if fallback_subnet_id
    puts "No tagged subnet found for #{tag_key}=#{tag_value}; tagging fallback subnet #{fallback_subnet_id}"
    return ensure_subnet_tag(
      ec2_client: ec2_client,
      subnet_id: fallback_subnet_id,
      tag_key: tag_key,
      tag_value: tag_value
    )
  end

  fail("No subnet found with #{tag_key}=#{tag_value}. Tag a subnet or pass --subnet-id once to auto-tag it.")
end

def run_command_with_log(label:, command:, env:, log_file:, stdout_to_console: false)
  FileUtils.mkdir_p(File.dirname(log_file))
  separator = "=" * 80
  timestamp = Time.now.utc.iso8601
  label_line = "[#{timestamp}] #{label}"
  log_line = "  log: #{log_file}"

  puts label_line
  puts log_line

  success = false
  File.open(log_file, "a") do |io|
    io.puts("#{separator}\n#{timestamp} #{label}\n#{separator}")
    io.puts("command: #{command.join(' ')}")
    io.flush
    success = system(env, *command, out: io, err: io)
  end

  return true if success

  puts "[ERROR] #{label} failed"
  if File.exist?(log_file)
    puts "Last 100 lines from #{log_file}:"
    tail_output = File.readlines(log_file).last(100).join
    puts tail_output.empty? ? "[No output captured]" : tail_output
  end

  puts "[TIP] Full log remains in #{log_file}" unless stdout_to_console
  return false
ensure
  unless stdout_to_console
    # Keep a concise marker in the console for successful runs
    puts "[OK] #{label}" if success
  end
end

def default_log_file
  options_log = ENV["RUNS_ON_PACKER_LOG"] || ENV["PACKER_LOG_FILE"]
  return options_log unless options_log.nil? || options_log.empty?

  File.join(Dir.tmpdir, "packer-build-#{Time.now.strftime('%Y%m%d-%H%M%S')}-#{Process.pid}.log")
end

image = IMAGES.find do |i|
  i['id'] == options[:image_id]
end
fail("Image not found: #{options[:image_id]}") unless image

image_id_parts = image['id'].split('-')
fail("Invalid image id: #{image['id']}") if image_id_parts.length < 3

dist = image_id_parts.first
arch = image_id_parts.last
variant = image_id_parts[1..-2].join('-')
release_dir = "releases/#{dist}/#{arch}"
fail "Skipping #{release_dir}, not found" unless Dir.exist?(release_dir)
patch_script = File.expand_path("../bin/patch/#{dist}-#{arch}", __dir__)
fail "Patch script not found: #{patch_script}" unless File.exist?(patch_script)

ami_name = [options[:image_prefix], image['id'], options[:image_version]].join('-')
legacy_subnet_id = options[:subnet_id] || ENV.fetch('SUBNET_ID', nil)
network_ec2_client = Aws::EC2::Client.new(region: options[:region])
resolved_subnet_id = resolve_subnet_id(
  ec2_client: network_ec2_client,
  tag_key: SUBNET_TAG_KEY,
  tag_value: SUBNET_TAG_VALUE,
  fallback_subnet_id: legacy_subnet_id
)
packer_template_relative_path = "#{dist.sub(/\d+$/, '')}/templates/#{image['id']}.pkr.hcl"
packer_template_path = "#{release_dir}/images/#{packer_template_relative_path}"
log_file_path = options[:log_file] || default_log_file
puts "Using Packer command log file: #{log_file_path}"
custom_amazon_plugin_binary = ENV.fetch('PACKER_AMAZON_PLUGIN_BINARY', '').strip
custom_plugin_path = ""

# Ensure template directory exists
FileUtils.mkdir_p(File.dirname(packer_template_path))

if options[:sync]
  sync_script = File.expand_path("../bin/sync", __dir__)
  unless run_command_with_log(
    label: "Sync generated files for #{options[:image_id]} before build",
    command: [sync_script, "--image-id", options[:image_id]],
    env: {},
    log_file: log_file_path
  )
    fail("Failed to sync #{options[:image_id]}")
  end
end

# Refresh the generated release tree from the repo patches before every build.
unless run_command_with_log(
  label: "Patch release tree #{release_dir}",
  command: [patch_script, release_dir],
  env: {},
  log_file: log_file_path
) 
  fail("Failed to patch #{release_dir}")
end

# Copy template to destination
FileUtils.cp("patches/#{packer_template_relative_path}", packer_template_path)

FileUtils.rm_rf("integrations") && Dir.mkdir("integrations")
{
  "runs-on/runner-images-for-stepsecurity" => "integrations/stepsecurity"
}.each do |repo, path|
  if options[:debug]
    puts "debug mode: copying local repo #{repo} to #{path}"
    puts "debug mode copy skipped from helper logging (requires shell expansion)"
    system("cp -r ~/dev/#{repo} #{path}") or fail("Failed to copy local repo #{repo}")
  else
    clone_urls = [
      "git@github.com:#{repo}.git",
      "https://github.com/#{repo}.git"
    ]
    cloned = clone_urls.any? do |clone_url|
      run_command_with_log(
        label: "Clone #{repo} via #{clone_url}",
        command: ["git", "clone", clone_url, path],
        env: {},
        log_file: log_file_path
      )
    end
    unless cloned
      fail("Failed to clone #{repo}")
    end
  end
end

at_exit do
  FileUtils.rm_rf(packer_template_path)
  FileUtils.rm_rf("integrations")
end

if custom_amazon_plugin_binary.empty?
  packer_init_cmd = [
    "packer", "init", "-upgrade",
    packer_template_path
  ]
else
  fail("Custom amazon plugin binary not found: #{custom_amazon_plugin_binary}") unless File.file?(custom_amazon_plugin_binary)

  custom_plugin_path = File.expand_path(
    ".tmp/packer/plugins/#{options[:image_id]}",
    File.expand_path("..", __dir__)
  )
  FileUtils.mkdir_p(custom_plugin_path)

  plugin_install_cmd = [
    "packer", "plugins", "install", "--force",
    "--path", custom_amazon_plugin_binary,
    "github.com/hashicorp/amazon"
  ]
  plugin_env = { "PACKER_PLUGIN_PATH" => custom_plugin_path }

  puts "Installing custom amazon plugin from #{custom_amazon_plugin_binary}"
  unless run_command_with_log(
    label: "Packer plugin install",
    command: plugin_install_cmd,
    env: plugin_env,
    log_file: log_file_path
  )
    fail("Packer plugin install failed")
  end

  packer_init_cmd = [
    "packer", "init",
    packer_template_path
  ]
end
packer_build_cmd = [
  "packer", "build",
  options[:debug] ? "-debug" : nil,
  "-var", %{ami_regions=["us-east-1"]},
  "-var", "ami_name=#{ami_name}",
  "-var", "image_os=#{dist}",
  "-var", "image_version=#{options[:image_version]}",
  "-var", "subnet_id=#{resolved_subnet_id}",
  "-var", "region=#{options[:region]}",
  "-var", "source_ami_name=#{image.fetch('source_ami_name')}",
  "-var", "source_ami_owner=#{image.fetch('source_ami_owner')}",
  ("-var" if image.key?('instance_type')),
  ("instance_type=#{image.fetch('instance_type')}" if image.key?('instance_type')),
  "-var", "volume_size=#{image.fetch('volume_size')}",
  ("-var" if image.key?('volume_throughput')),
  ("volume_throughput=#{image.fetch('volume_throughput')}" if image.key?('volume_throughput')),
  ("-var" if image.key?('payload_volume_size')),
  ("payload_volume_size=#{image.fetch('payload_volume_size')}" if image.key?('payload_volume_size')),
  ("-var" if ENV.key?("INCLUDE_FULL_INSTALLERS")),
  ("include_full_installers=#{ENV.fetch('INCLUDE_FULL_INSTALLERS')}" if ENV.key?("INCLUDE_FULL_INSTALLERS")),
  "-var", "ami_description=#{image.fetch('description')}",
  packer_template_path
].compact

packer_init_env = { "PACKER_LOG" => "0" }
unless custom_plugin_path.empty?
  packer_init_env["PACKER_PLUGIN_PATH"] = custom_plugin_path
end

puts "Running Packer init command..."
unless run_command_with_log(
  label: "Packer init",
  command: packer_init_cmd,
  env: packer_init_env,
  log_file: log_file_path
)
  fail("Packer init failed")
end

packer_build_env = { "PROJECT_ROOT" => File.expand_path("..", __dir__) }
unless custom_plugin_path.empty?
  packer_build_env["PACKER_PLUGIN_PATH"] = custom_plugin_path
end

puts "Running Packer build command..."

windows_disk_monitor_pid = nil
if options[:image_id].start_with?("windows")
  monitor_script = File.expand_path("../scripts/monitor-windows-builder-disk.sh", __dir__)
  if File.executable?(monitor_script)
    windows_metrics_file = ENV.fetch("WINDOWS_METRICS_FILE", File.expand_path("../WINDOWS_METRICS.md", __dir__))
    windows_metrics_interval_sec = ENV.fetch("WINDOWS_METRICS_INTERVAL_SEC", "180")

    monitor_cmd = [
      monitor_script,
      "--ami-name", ami_name,
      "--region", options[:region],
      "--interval-sec", windows_metrics_interval_sec,
      "--metrics-file", windows_metrics_file
    ]
    aws_profile = ENV.fetch("AWS_PROFILE", "").strip
    monitor_cmd += ["--profile", aws_profile] unless aws_profile.empty?

    puts "Starting Windows disk monitor command: #{monitor_cmd.join(' ')}"
    windows_disk_monitor_pid = Process.spawn(packer_build_env, *monitor_cmd)
  else
    puts "Windows disk monitor script not executable: #{monitor_script}; skipping disk metrics tracking"
  end
end

build_succeeded = false
begin
  build_succeeded = run_command_with_log(
    label: "Packer build",
    command: packer_build_cmd,
    env: packer_build_env,
    log_file: log_file_path
  )
  raise("Packer build failed") unless build_succeeded
ensure
  unless windows_disk_monitor_pid.nil?
    begin
      Process.kill("TERM", windows_disk_monitor_pid)
    rescue Errno::ESRCH
    end

    begin
      Timeout.timeout(10) { Process.wait(windows_disk_monitor_pid) }
    rescue Timeout::Error
      begin
        Process.kill("KILL", windows_disk_monitor_pid)
      rescue Errno::ESRCH
      end
      begin
        Process.wait(windows_disk_monitor_pid)
      rescue Errno::ECHILD
      end
    rescue Errno::ECHILD
    end
  end
end

unless build_succeeded
  # Cleanup any dangling EC2 instances
  ec2_client = Aws::EC2::Client.new(region: 'us-east-1')
  instances = ec2_client.describe_instances(
    filters: [
      { name: 'instance-state-name', values: ['running', 'pending', 'stopping', 'stopped'] },
      { name: 'tag:ami_name', values: [ami_name] }
    ]
  ).reservations.flat_map(&:instances)

  instances.each do |instance|
    puts "Terminating instance #{instance.instance_id}"
    ec2_client.terminate_instances(instance_ids: [instance.instance_id])
  end

  fail("Packer build failed")
end

# Fetch AMI ID corresponding to AMI name
ec2_client = Aws::EC2::Client.new(region: 'us-east-1')
ami_id = nil

begin
  response = ec2_client.describe_images({
    filters: [{ name: 'name', values: [ami_name] }]
  })
  
  if response.images.any?
    ami_id = response.images.first.image_id
    puts "Found AMI ID: #{ami_id} for AMI name: #{ami_name}"
  else
    puts "No AMI found with name: #{ami_name}"
  end
rescue Aws::EC2::Errors::ServiceError => e
  puts "Error fetching AMI ID: #{e.message}"
end


if github_output_file = ENV.fetch('GITHUB_OUTPUT', nil)
  File.open(github_output_file, 'a') do |f|
    f.puts "ami_name=#{ami_name}"
    f.puts "ami_id=#{ami_id}"
  end
  puts "AMI name #{ami_name} and ID #{ami_id} added to GitHub Actions outputs"
end

if github_step_summary_file = ENV.fetch('GITHUB_STEP_SUMMARY', nil)
  File.open(github_step_summary_file, 'a') do |f|
    f.puts "## #{image['id']}"
    f.puts "- **AMI Name:** `#{ami_name}`"
    f.puts "- **AMI ID:** `#{ami_id}`"
  end
end
