#!/usr/bin/env ruby

require 'json'
require 'open-uri'
require 'slop'
require 'fileutils'
require 'yaml'
require 'aws-sdk-ec2'
require 'timeout'

IMAGES = YAML.load_file(File.expand_path("../config.yml", __dir__)).fetch("images")

options = {}

usage = Slop::Options.new do |opts|
  opts.banner = "Usage: #{$0} --image-id [IMAGE_ID]"

  opts.string '--image-id', 'Image ID', required: true
  opts.string '--image-prefix', 'Image Prefix', default: ENV.fetch('AMI_PREFIX', "runs-on-dev")
  opts.string '--image-version', 'Image Version', default: Time.now.strftime("%Y%m%d%H%M%S")
  opts.string '--subnet-id', 'Subnet ID', default: ENV.fetch('SUBNET_ID', nil)
  opts.string '--region', 'Region', default: ENV.fetch('AWS_DEFAULT_REGION', "us-east-1")
  opts.boolean '--debug', 'Debug mode', default: false
end

begin
  options = usage.parse(ARGV).to_hash
rescue Slop::Error => e
  puts "Error: #{e.message}"
  puts
  puts usage
  exit 1
end

image = IMAGES.find do |i|
  i['id'] == options[:image_id]
end
fail("Image not found: #{options[:image_id]}") unless image

dist, variant, arch = image['id'].split('-', 3)
release_dir = "releases/#{dist}/#{arch}"
fail "Skipping #{release_dir}, not found" unless Dir.exist?(release_dir)

ami_name = [options[:image_prefix], image['id'], options[:image_version]].join('-')
packer_template_relative_path = "#{dist.sub(/\d+$/, '')}/templates/#{image['id']}.pkr.hcl"
packer_template_path = "#{release_dir}/images/#{packer_template_relative_path}"
custom_amazon_plugin_binary = ENV.fetch('PACKER_AMAZON_PLUGIN_BINARY', '').strip
custom_plugin_path = ""

# Ensure template directory exists
FileUtils.mkdir_p(File.dirname(packer_template_path))

# Copy template to destination
FileUtils.cp("patches/#{packer_template_relative_path}", packer_template_path)

FileUtils.rm_rf("integrations") && Dir.mkdir("integrations")
{
  "runs-on/runner-images-for-stepsecurity" => "integrations/stepsecurity"
}.each do |repo, path|
  if options[:debug]
    puts "debug mode: copying local repo #{repo} to #{path}"
    system("cp -r ~/dev/#{repo} #{path}")
  else
    system("git clone git@github.com:#{repo}.git #{path}")
  end
end

at_exit do
  FileUtils.rm_rf(packer_template_path)
  FileUtils.rm_rf("integrations")
end

if custom_amazon_plugin_binary.empty?
  packer_init_cmd = [
    "packer", "init", "-upgrade",
    packer_template_path
  ]
else
  fail("Custom amazon plugin binary not found: #{custom_amazon_plugin_binary}") unless File.file?(custom_amazon_plugin_binary)

  custom_plugin_path = File.expand_path(
    ".tmp/packer/plugins/#{options[:image_id]}",
    File.expand_path("..", __dir__)
  )
  FileUtils.mkdir_p(custom_plugin_path)

  plugin_install_cmd = [
    "packer", "plugins", "install", "--force",
    "--path", custom_amazon_plugin_binary,
    "github.com/hashicorp/amazon"
  ]
  plugin_env = { "PACKER_PLUGIN_PATH" => custom_plugin_path }

  puts "Installing custom amazon plugin from #{custom_amazon_plugin_binary}"
  puts "Running Packer plugin install command: #{plugin_install_cmd.join(' ')}"
  system(plugin_env, *plugin_install_cmd) or fail("Packer plugin install failed")

  packer_init_cmd = [
    "packer", "init",
    packer_template_path
  ]
end
packer_build_cmd = [
  "packer", "build",
  options[:debug] ? "-debug" : nil,
  "-var", %{ami_regions=["us-east-1"]},
  "-var", "ami_name=#{ami_name}",
  "-var", "image_os=#{dist}",
  "-var", "image_version=#{options[:image_version]}",
  "-var", "subnet_id=#{options[:subnet_id]}",
  "-var", "region=#{options[:region]}",
  "-var", "source_ami_name=#{image.fetch('source_ami_name')}",
  "-var", "source_ami_owner=#{image.fetch('source_ami_owner')}",
  ("-var" if image.key?('instance_type')),
  ("instance_type=#{image.fetch('instance_type')}" if image.key?('instance_type')),
  "-var", "volume_size=#{image.fetch('volume_size')}",
  "-var", "ami_description=#{image.fetch('description')}",
  packer_template_path
].compact

packer_init_env = { "PACKER_LOG" => "0" }
unless custom_plugin_path.empty?
  packer_init_env["PACKER_PLUGIN_PATH"] = custom_plugin_path
end

puts "Running Packer init command: #{packer_init_cmd.join(' ')}"
system(packer_init_env, *packer_init_cmd) or fail("Packer init failed")

packer_build_env = { "PROJECT_ROOT" => File.expand_path("..", __dir__) }
unless custom_plugin_path.empty?
  packer_build_env["PACKER_PLUGIN_PATH"] = custom_plugin_path
end

puts "Running Packer build command: #{packer_build_cmd.join(' ')}"

windows_disk_monitor_pid = nil
if options[:image_id].start_with?("windows")
  monitor_script = File.expand_path("../scripts/monitor-windows-builder-disk.sh", __dir__)
  if File.executable?(monitor_script)
    windows_metrics_file = ENV.fetch("WINDOWS_METRICS_FILE", File.expand_path("../WINDOWS_METRICS.md", __dir__))
    windows_metrics_interval_sec = ENV.fetch("WINDOWS_METRICS_INTERVAL_SEC", "180")

    monitor_cmd = [
      monitor_script,
      "--ami-name", ami_name,
      "--region", options[:region],
      "--interval-sec", windows_metrics_interval_sec,
      "--metrics-file", windows_metrics_file
    ]
    aws_profile = ENV.fetch("AWS_PROFILE", "").strip
    monitor_cmd += ["--profile", aws_profile] unless aws_profile.empty?

    puts "Starting Windows disk monitor command: #{monitor_cmd.join(' ')}"
    windows_disk_monitor_pid = Process.spawn(packer_build_env, *monitor_cmd)
  else
    puts "Windows disk monitor script not executable: #{monitor_script}; skipping disk metrics tracking"
  end
end

build_succeeded = false
begin
  build_succeeded = system(packer_build_env, *packer_build_cmd)
ensure
  unless windows_disk_monitor_pid.nil?
    begin
      Process.kill("TERM", windows_disk_monitor_pid)
    rescue Errno::ESRCH
    end

    begin
      Timeout.timeout(10) { Process.wait(windows_disk_monitor_pid) }
    rescue Timeout::Error
      begin
        Process.kill("KILL", windows_disk_monitor_pid)
      rescue Errno::ESRCH
      end
      begin
        Process.wait(windows_disk_monitor_pid)
      rescue Errno::ECHILD
      end
    rescue Errno::ECHILD
    end
  end
end

unless build_succeeded
  # Cleanup any dangling EC2 instances
  ec2_client = Aws::EC2::Client.new(region: 'us-east-1')
  instances = ec2_client.describe_instances(
    filters: [
      { name: 'instance-state-name', values: ['running', 'pending', 'stopping', 'stopped'] },
      { name: 'tag:ami_name', values: [ami_name] }
    ]
  ).reservations.flat_map(&:instances)

  instances.each do |instance|
    puts "Terminating instance #{instance.instance_id}"
    ec2_client.terminate_instances(instance_ids: [instance.instance_id])
  end

  fail("Packer build failed")
end

# Fetch AMI ID corresponding to AMI name
ec2_client = Aws::EC2::Client.new(region: 'us-east-1')
ami_id = nil

begin
  response = ec2_client.describe_images({
    filters: [{ name: 'name', values: [ami_name] }]
  })
  
  if response.images.any?
    ami_id = response.images.first.image_id
    puts "Found AMI ID: #{ami_id} for AMI name: #{ami_name}"
  else
    puts "No AMI found with name: #{ami_name}"
  end
rescue Aws::EC2::Errors::ServiceError => e
  puts "Error fetching AMI ID: #{e.message}"
end


if github_output_file = ENV.fetch('GITHUB_OUTPUT', nil)
  File.open(github_output_file, 'a') do |f|
    f.puts "ami_name=#{ami_name}"
    f.puts "ami_id=#{ami_id}"
  end
  puts "AMI name #{ami_name} and ID #{ami_id} added to GitHub Actions outputs"
end

if github_step_summary_file = ENV.fetch('GITHUB_STEP_SUMMARY', nil)
  File.open(github_step_summary_file, 'a') do |f|
    f.puts "## #{image['id']}"
    f.puts "- **AMI Name:** `#{ami_name}`"
    f.puts "- **AMI ID:** `#{ami_id}`"
  end
end
